# document-processor — environment variables
# Copy to `.env` and adjust. `.env` is git-ignored.

# ============================================================================
# Tauri build / dev
# ============================================================================

# Set to "true" (or any non-empty value) to disable JS minification and
# emit source maps. Used by vite.config.js. Default: minified.
# TAURI_DEBUG=true

# ============================================================================
# Rust runtime diagnostics
# ============================================================================

# Increase Rust log verbosity. Recognised by the env_logger /
# tracing-subscriber crates if either is in use. Examples:
#   RUST_LOG=info
#   RUST_LOG=document_processor=debug
# RUST_LOG=info

# Emit a Rust backtrace on panic. Useful when filing bug reports.
# RUST_BACKTRACE=1
